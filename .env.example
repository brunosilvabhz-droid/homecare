POSTGRES_PASSWORD=troque-por-uma-senha-forte
DATABASE_URL=postgresql+psycopg://impactocare:troque-por-uma-senha-forte@db:5432/impactocare
JWT_SECRET=troque-por-uma-chave-segura-com-32-caracteres
GOOGLE_CLIENT_ID=
TURNSTILE_SECRET_KEY=
