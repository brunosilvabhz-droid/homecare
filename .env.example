CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Sem SMTP, o link de confirmação aparece nos logs da API (somente desenvolvimento).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=nao-responda@impactocg.com
SUPPORT_EMAIL=contato@impactocg.com
SMTP_USE_TLS=true
# ASAAS Sandbox. Nunca exponha a chave no frontend.
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_CHECKOUT_URL=https://sandbox.asaas.com/checkoutSession/show
ASAAS_WEBHOOK_TOKEN=
# IA sob demanda. A chave fica somente no backend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# WhatsApp Business Cloud API da conta Impacto Care.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
